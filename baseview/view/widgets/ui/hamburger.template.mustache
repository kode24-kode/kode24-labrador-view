<div class="hamburger to-be-expanded[[ #settings.classes ]] [[.]][[ /settings.classes ]]" data-id="pageElements-[[ id ]]">
    <div class="positionRelative">
        <span class="hamburger-button hamburger-expander [[ #settings.textAsButton ]]hamburger-button-text[[ /settings.textAsButton]]">
            <button class="burger-btn" aria-label="[[ #settings.label ]][[ settings.label]][[ /settings.label ]][[ ^settings.label ]]{{ #lang }}hamburger.collapsedLabel{{ /lang }}[[ /settings.label ]]" aria-expanded="false" aria-controls="hamburger-container" aria-haspopup="menu">
                [[ ^settings.textAsButton ]]
                    [[ #settings.textBeforeIcon ]]
                        <span class="textBeforeIcon">{{ #lang }}hamburger.buttonText{{ /lang }}</span>
                    [[ /settings.textBeforeIcon ]]
                    <i class="open [[ ^settings.icon_open ]]fi-list[[ /settings.icon_open ]][[ settings.icon_open ]]"></i>
                    <i class="close [[ ^settings.icon_close ]]fi-x[[ /settings.icon_close ]][[ settings.icon_close ]]"></i>
                    [[ #settings.textAfterIcon ]]
                        <span class="textAfterIcon">{{ #lang }}hamburger.buttonText{{ /lang }}</span>
                    [[ /settings.textAfterIcon ]]
                [[ /settings.textAsButton ]]
                [[ #settings.textAsButton ]]
                    <span class="open">[[ settings.textOpen ]]</span>
                    <span class="close">[[ settings.textClose ]]</span>
                [[ /settings.textAsButton ]]
            </button>
        </span>
        [[ ^settings.positionContainerAbsolute ]]
            <div class="hamburger-container" id="hamburger-container">        
                [[& children ]]
                {{ #getConfig.footer.include.addFooterToBurger }}
                {{ #selector.esi_footer }}
                <footer class="page">
                    {{{ selector.esi_footer }}}
                </footer>
                {{ /selector.esi_footer }}
                {{ /getConfig.footer.include.addFooterToBurger }}
            </div>
        [[ /settings.positionContainerAbsolute ]]
    </div>

    [[ #settings.positionContainerAbsolute ]]
        <div class="hamburger-container" id="hamburger-container">
        [[ ^settings.noRow ]]
            <div class="row">
        [[ /settings.noRow ]]
                [[& children ]]
        [[ ^settings.noRow ]]
            </div>
        [[ /settings.noRow ]]
        {{ #getConfig.footer.include.addFooterToBurger }}
        {{ #selector.esi_footer }}
        <footer class="page">
            {{{ selector.esi_footer }}}
        </footer>
        {{ /selector.esi_footer }}
        {{ /getConfig.footer.include.addFooterToBurger }}
        </div>
    [[ /settings.positionContainerAbsolute ]]
</div>

<script>
    (function(){
        const burgerButton = document.querySelector('[data-id="pageElements-[[ id ]]"] .burger-btn');
        const dropdownCloseSection = document.querySelector('[data-id="pageElements-[[ id ]]"] .dropdown-close-section');
        const hamburgerContainer = document.querySelector('[data-id="pageElements-[[ id ]]"] .hamburger-container');

        function toggleDropdown() {
            // Toggle the expanded class and aria-expanded attribute
            document.querySelector('[data-id="pageElements-[[ id ]]"].hamburger.to-be-expanded').classList.toggle('expanded');
            burgerButton.setAttribute('aria-expanded', burgerButton.getAttribute('aria-expanded') === 'true' ? 'false' : 'true');
            burgerButton.setAttribute('aria-label', burgerButton.getAttribute('aria-expanded') === 'true' ? '{{ #lang }}hamburger.expandedLabel{{ /lang }}' : '{{ #lang }}hamburger.collapsedLabel{{ /lang }}');

            // This doesn't seem to do anything? But there's styling dependent on it some places
            document.body.classList.toggle('hamburger-expanded');
        }

        function getFocusableElements() {
            if (!hamburgerContainer) return [];
            return Array.from(hamburgerContainer.querySelectorAll(
                'a[href], button:not([disabled]), input:not([disabled]), ' +
                'select:not([disabled]), textarea:not([disabled]), [tabindex]:not([tabindex="-1"])'
            )).filter(function(el) {
                if (el.closest('[hidden]')) return false;
                if (getComputedStyle(el).visibility === 'hidden') return false;
                const rect = el.getBoundingClientRect();
                return rect.width > 0 || rect.height > 0;
            });
        }

        // Called via the event listener - handles Escape (close menu, restore focus) and
        // Tab (trap focus within the open menu)
        function handleKeydown(e) {
            if (e.key === 'Escape') {
                toggleDropdown();
                // Set the focus back on the button when clicking escape, so the user can continue tabbing down
                // the page in a natural flow
                burgerButton.focus();
                window.removeEventListener('keydown', handleKeydown);
                return;
            }

            if (e.key === 'Tab') {
                const focusable = getFocusableElements();
                if (focusable.length === 0) return;

                if (!e.shiftKey && document.activeElement === focusable[focusable.length - 1]) {
                    // Tab past last item → burger button
                    e.preventDefault();
                    burgerButton.focus();
                } else if (e.shiftKey && document.activeElement === burgerButton) {
                    // Shift+Tab from burger button → last item
                    e.preventDefault();
                    focusable[focusable.length - 1].focus();
                }
            }
        }

        if(burgerButton) {
            burgerButton.addEventListener('click', function(e) {
                e.preventDefault();
                toggleDropdown();

                // If the menu gets expanded, add the event listener that will close it on pressing Escape
                // else, remove the event listener otherwise it will continue to listen for escape even if the menu is closed.
                if(burgerButton.getAttribute('aria-expanded') === 'true') {
                    window.addEventListener('keydown', handleKeydown);
                } else {
                    window.removeEventListener('keydown', handleKeydown);
                }
            })
        }
        if (dropdownCloseSection) {
            dropdownCloseSection.addEventListener('click', function(e) {
                e.preventDefault();
                toggleDropdown();
            });
        }

        document.querySelectorAll('.hamburger .hamburger-expander, .hamburger .hamburger-container, .stop-propagation').forEach(function (element) {
            element.addEventListener('click', function (e) {
                e.stopPropagation();
            });
        });
    }());
</script>