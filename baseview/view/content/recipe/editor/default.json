    "toolMenus": {
        "rich_text": {
            "inheritPath": "menu/tool/rich_text.json"
        }
    },
    "contentMenus": {
        "default": {
            "inheritPath": "menu/content/basemenu.json",
            "items": {
                "style": {
                    "inheritPath": "menu/buttons/styles.json",
                    "group": "g4"
                },
                "imagePosition": {
                    "inheritPath": "content/recipe/menu/recipeImagePosition.json",
                    "group": "g2",
                    "title": "Image position"
                },
                "editSettings": {
                    "group": "g5",
                    "icon": "labicon-edit",
                    "callback": "displaySettingsPanel",
                    "title": "Recipe settings (,)",
                    "hotkeys": [
                        {
                            "key": ","
                        }
                    ],
                    "params": {
                        "settingsPanelOptions": "settingsPanels.admin"
                    }
                },
                "addRecipe": {
                    "text": "Add",
                    "group": "g5",
                    "items": {
                        "addRecipeIngredients": {
                            "title": "Add recipe ingredients",
                            "text": "Ingredients",
                            "callbacks": [
                                "dispatch"
                            ],
                            "params": {
                                "function": "recipe.insertIngredients"
                            }
                        },
                        "addRecipeInstructions": {
                            "title": "Add recipe instructions",
                            "text": "Instructions",
                            "callbacks": [
                                "dispatch"
                            ],
                            "params": {
                                "function": "recipe.insertInstructions"
                            }
                        }
                    }
                }
            }
        }
    },
    "settingsPanels": {
        "admin": {
            "template": "content/recipe/template/settings"
        }
    },
    "droppable": {
        "active": true,
        "accept": "*",
        "drop": {
            "sourceType": {
                "image": "replaceChild",
                "graphic": "replaceChild"
            },
            "default": "default"
        },
        "filedrop": "replaceChild"
    },
    "draggable": {
        "active": true
    },
    "redrawPaths": {
        "current": ["fields.author"]
    },
    "placeholders": [
        {
            "name": "no_media",
            "conditions": [
                {
                    "fn": "noChildOfTypes",
                    "params": {
                        "modelTypes": [
                            "image",
                            "graphic"
                        ]
                    }
                }
            ],
            "templatePath": "content/image/template/placeholder",
            "handlers": [
                {
                    "selector": ".addImageBtn",
                    "trigger": [
                        "click"
                    ],
                    "fn": "lab_api.v1.collection.display",
                    "param": {
                        "name": "MediaImages"
                    }
                }
            ]
        }
    ]
}
