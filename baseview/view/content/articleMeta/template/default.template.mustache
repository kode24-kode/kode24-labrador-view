<div data-element-guid="{{ get.current.guid }}" class="meta{{ ^children.byline[0] }} no-bylines{{ /children.byline[0] }}">
    
    {{ > content/articleMeta/template/partials/top }}

    <div class="bylines">
        {{ #app.isEditor }}
            {{ ^children.byline[0] }}
                <div>Drop bylines here ...</div>
            {{ /children.byline[0] }}
        {{ /app.isEditor }}        
        {{ ^getConfig.paywall.article.hideBylines }}{{{ children.byline }}}{{ /getConfig.paywall.article.hideBylines }}
        {{ #getConfig.paywall.article.hideBylines }}{{ #get.root.filtered.paywall.hasAccess }}{{{ children.byline }}}{{ /get.root.filtered.paywall.hasAccess }}{{ /getConfig.paywall.article.hideBylines }}
    </div>

    {{ #get.parent.metadata.showSection }}
        {{ #get.parent.metadata.sectionInDateline }}
            {{ #get.parent.metadata.sectionLabelHasLink }}
                <a href="{{{ get.parent.filtered.sectionLink }}}" class="lab-article-section-link dateline">
            {{ /get.parent.metadata.sectionLabelHasLink }}
            <span style="{{ #style.collection }}text_decoration_inline_style fields.section{{ /style.collection }}" class="{{ #style.collection }}text_decoration fields.section{{ /style.collection }} lab-article-section">
                {{ get.parent.filtered.sectionDisplayName }}
                {{ #app.isEditor }}
                    {{ ^get.parent.filtered.sectionDisplayName }}Section{{ /get.parent.filtered.sectionDisplayName }}
                {{ /app.isEditor }}
            </span>
            {{ #get.parent.metadata.sectionLabelHasLink }}
                </a>
            {{ /get.parent.metadata.sectionLabelHasLink }}
        {{ /get.parent.metadata.sectionInDateline }}
    {{ /get.parent.metadata.showSection }}

    {{ #get.parent.metadata.showSubsection }}
        {{ #get.parent.metadata.subsectionLabelHasLink }}
            <a href="{{{ get.parent.filtered.subsectionLink }}}" class="lab-article-subsection-link">
        {{ /get.parent.metadata.subsectionLabelHasLink }}
        <span class="lab-article-subsection">
            {{ get.parent.filtered.subsection }}
        </span>
        {{ #get.parent.metadata.subsectionLabelHasLink }}
            </a>
        {{ /get.parent.metadata.subsectionLabelHasLink }}
    {{ /get.parent.metadata.showSubsection }}
    
    <div class="dates">
        {{ ^get.current.filtered.date.unified.hide }}
        <span class="dateGroup dateUnified">
            <span class="dateLabel">{{{ get.current.filtered.date.unified.label }}}</span>
            <time datetime="{{{ get.current.filtered.date.unified.isoDate }}}">{{{ get.current.filtered.date.unified.formatted }}}</time>
        </span>
        {{ /get.current.filtered.date.unified.hide }}
        {{ ^get.current.filtered.date.published.hide }}
        <span class="dateGroup datePublished">
         {{ #get.current.filtered.unpublished }}
            <span class="dateLabel">{{ #lang }}metadata.unpublishedLabel{{ /lang }}</span>
            <time datetime="{{{ get.current.filtered.date.published.isoDate }}}">{{{ get.current.filtered.date.published.formatted }}}</time>
         {{ /get.current.filtered.unpublished }}
         {{ ^get.current.filtered.unpublished }}
            {{ ^getConfig.articleMetaSettings.hidePublishedDateLabel }}<span class="dateLabel">{{ #lang }}metadata.publishedLabel{{ /lang }}</span>{{ /getConfig.articleMetaSettings.hidePublishedDateLabel }}
            <time datetime="{{{ get.current.filtered.date.published.isoDate }}}">{{{ get.current.filtered.date.published.formatted }}}</time>
         {{ /get.current.filtered.unpublished }}
        </span>
        {{ /get.current.filtered.date.published.hide }}
        {{ ^get.current.filtered.date.modified.hide }}
        {{ ^getConfig.articleMetaSettings.hideModifiedDate }}
        {{ #get.current.filtered.date.modified.formatted }}
            <span class="dateGroup dateModified">
                {{ ^getConfig.articleMetaSettings.hideModifiedDateLabel }}<span class="dateLabel">{{ #lang }}metadata.modifiedLabel{{ /lang }}</span>{{ /getConfig.articleMetaSettings.hideModifiedDateLabel }}
                <time datetime="{{{ get.current.filtered.date.modified.isoDate }}}">{{{ get.current.filtered.date.modified.formatted }}}</time>
            </span>
        {{ /get.current.filtered.date.modified.formatted }}
        {{ /getConfig.articleMetaSettings.hideModifiedDate }}
        {{ /get.current.filtered.date.modified.hide }}
    </div>

    {{ #getConfig.displayReadTime.active }}
    {{ #get.current.fields.displayReadTime }}
    <div class="read-time">
        <span>{{ ^getConfig.displayReadTime.hideReadTimeLabel }}{{ #lang }}metadata.readTimeLabel{{ /lang }}: {{ /getConfig.displayReadTime.hideReadTimeLabel }}<span class="read-time-value">{{ get.current.filtered.readTime }}</span></span>
    </div>
    {{ /get.current.fields.displayReadTime }}
    {{ /getConfig.displayReadTime.active }}

    {{ #get.root.filtered.page_settings.social.display.header }}
    <div class="social">
        {{ #get.root.filtered.page_settings.social.items }}
        {{ > partial/social_button }}
        {{ /get.root.filtered.page_settings.social.items }}
    </div>
    {{ /get.root.filtered.page_settings.social.display.header }}

    {{ #get.root.filtered.google_translate.active }}
    <div class="translate">
        {{ #get.root.filtered.google_translate.lang }}
        <a href="https://translate.google.com/translate?sl=no&tl={{ . }}&u={{{ get.root.filtered.urlEncoded }}}" target="_blank">
            <figure><img src="/view-resources/baseview/public/common/flags/svg/{{ . }}.svg" alt="{{ . }}"></figure>
        </a>
        {{ /get.root.filtered.google_translate.lang }}
    </div>
    {{ /get.root.filtered.google_translate.active }}

    {{ #get.root.filtered.embeddable.aboveBodytext }}
        {{> partial/embedThis}}
    {{ /get.root.filtered.embeddable.aboveBodytext }}

</div>
