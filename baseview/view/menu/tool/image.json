{
    "position": "top",
    "style": {
        "margin-top": "-10px"
    },
    "items": {
        "reset": {
            "icon": "labicon-imgExpand",
            "title": "Reset to original dimensions",
            "group": "g4",
            "callback": "reset"
        },
        "setFrontCrop": {
            "icon": "labicon-imgFrontCrop",
            "title": "Use image as front-crop",
            "group": "g4",
            "callback": "dispatchToolMethod",
            "displayCondition": "pageIsArticlePage",
            "params": {
                "function": "setFrontCrop"
            }
        },
        "advanced": {
            "title": "Advanced settings. Displayed on bottom of page",
            "icon": "labicon-edit",
            "group": "g5",
            "callback": "displaySettings"
        },
        "aspectRatio": {
            "icon": "labicon-image_fullscreen",
            "title": "Apply aspect ratio",
            "group": "g6",
            "submenuDirection": "lab-align-left",
            "items": {
                "ratio_16_9": {
                    "text": "16:9",
                    "title": "16:9 — widescreen",
                    "callback": "dispatchToolMethod",
                    "params": {
                        "function": "applyAspectRatio",
                        "ratio": 1.7778
                    },
                    "hotkeys": [{ "key": "1" }],
                    "displayHotkeys": true
                },
                "ratio_3_2": {
                    "text": "3:2",
                    "title": "3:2 — classic photo",
                    "callback": "dispatchToolMethod",
                    "params": {
                        "function": "applyAspectRatio",
                        "ratio": 1.5
                    },
                    "hotkeys": [{ "key": "2" }],
                    "displayHotkeys": true
                },
                "ratio_4_3": {
                    "text": "4:3",
                    "title": "4:3 — standard",
                    "callback": "dispatchToolMethod",
                    "params": {
                        "function": "applyAspectRatio",
                        "ratio": 1.3333
                    },
                    "hotkeys": [{ "key": "3" }],
                    "displayHotkeys": true
                },
                "ratio_1_1": {
                    "text": "1:1",
                    "title": "1:1 — square",
                    "callback": "dispatchToolMethod",
                    "params": {
                        "function": "applyAspectRatio",
                        "ratio": 1.0
                    },
                    "hotkeys": [{ "key": "4" }],
                    "displayHotkeys": true
                },
                "ratio_9_16": {
                    "text": "9:16",
                    "title": "9:16 — portrait",
                    "callback": "dispatchToolMethod",
                    "params": {
                        "function": "applyAspectRatio",
                        "ratio": 0.5625
                    },
                    "hotkeys": [{ "key": "5" }],
                    "displayHotkeys": true
                }
            }
        },
        "alignLeft": {
            "title": "Toggle image-alignment left",
            "icon": "labicon-align_content_left",
            "group": "g6",
            "callback": "toggleImageAlignment",
            "onValue": "floatLeft",
            "offValue": false,
            "params": {
                "isLeft": true
            },
            "bindings": [
                {
                    "path": "fields.float",
                    "attribute": "value"
                }
            ]
        },
        "alignRight": {
            "title": "Toggle image-alignment right",
            "icon": "labicon-align_content_right",
            "group": "g6",
            "callback": "toggleImageAlignment",
            "onValue": "floatRight",
            "offValue": false,
            "params": {
                "isLeft": false
            },
            "bindings": [
                {
                    "path": "fields.float",
                    "attribute": "value"
                }
            ]
        },
        "end": {
            "title": "Save and end tool",
            "text": "Done",
            "group": "g7",
            "callback": "end"
        }
    }
}